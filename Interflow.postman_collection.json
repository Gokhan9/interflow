	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/health",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"health"
					]
				}
			},
			"response": []
		},
		{
			"name": "Chat Completion (OpenAI)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					},
					{
						"key": "X-Provider",
						"value": "openai",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"model\": \"gpt-3.5-turbo\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, how are you?\"\n    }\n  ],\n  \"temperature\": 0.7,\n  \"max_tokens\": 500\n}"
				},
				"url": {
					"raw": "{{base_url}}/v1/chat",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"v1",
						"chat"
					]
				}
			},
			"response": []
		},
		{
			"name": "Invalid API Key Test",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "X-API-Key",
						"value": "invalid-key",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"model\": \"gpt-3.5-turbo\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello\"\n    }\n  ]\n}"
				},
				"url": {
					"raw": "{{base_url}}/v1/chat",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"v1",
						"chat"
					]
				}
			},
			"response": []
		}
